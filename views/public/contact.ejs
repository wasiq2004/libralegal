<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us | Libra Legal Hub</title>
  <meta name="description"
    content="Contact Libra Legal Consultancy — Dubai, UAE. Free initial consultation available." />
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>

  <div id="nav-placeholder"></div>

  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="container page-hero-content">
      <span class="eyebrow fade-in">Get In Touch</span>
      <h1 class="fade-in" data-delay="100">Contact Us</h1>
      <div class="fade-in" data-delay="200" style="width:60px;height:2px;background:var(--gold);margin:20px 0 24px;">
      </div>
      <p class="fade-in" data-delay="300">Our legal team is available to assist with advisory, regulatory, and
        dispute-related matters across the UAE. Contact us to arrange a confidential initial consultation.</p>
    </div>
  </section>

  <section class="contact-section section-pad">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info fade-in-left">
          <span class="eyebrow">Reach Our Team</span>
          <h2>Speak with a Legal Practitioner</h2>
          <p>For legal advisory, regulatory guidance, or dispute-related matters, our team is available to assist. We
            offer a free initial consultation for all new enquiries.</p>

          <div class="contact-info-stack">
            <div class="contact-detail">
              <div class="contact-icon">📍</div>
              <div class="contact-detail-info">
                <label>Address</label>
                <strong>Libra Legal Consultancy</strong>
                <a href="#">Dubai, United Arab Emirates & Egypt</a>
              </div>
            </div>

            <div class="contact-detail">
              <div class="contact-icon">✉</div>
              <div class="contact-detail-info">
                <label>Email</label>
                <strong>General Enquiries</strong>
                <a href="mailto:info@libralegalconsultancy.com">info@libralegalconsultancy.com</a>
              </div>
            </div>

            <div class="contact-detail">
              <div class="contact-icon">📞</div>
              <div class="contact-detail-info">
                <label>Phone</label>
                <strong>Direct Line</strong>
                <a href="tel:+971581216686">+971 58 121 6686</a>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-column fade-in-right" data-delay="150">
          <div class="contact-form">
            <h3>Send a Message</h3>
            <form id="contactForm" novalidate>
              <input type="hidden" name="access_key" value="<%= web3formsAccessKey %>" />
              <input type="hidden" name="subject" value="New enquiry from Libra Legal Consultancy website" />
              <input type="hidden" name="from_name" value="Libra Legal Consultancy Website" />
              <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none;" />

              <div class="form-row">
                <div class="form-group">
                  <label for="fullName">Full Name *</label>
                  <input type="text" id="fullName" name="name" aria-label="Full Name" placeholder="Your full name"
                    required />
                </div>
                <div class="form-group">
                  <label for="email">Email Address *</label>
                  <input type="email" id="email" name="email" aria-label="Email Address" placeholder="your@email.com"
                    required />
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="phone">Phone (optional)</label>
                  <input type="tel" id="phone" name="phone" aria-label="Phone Number" placeholder="+971 xx xxx xxxx" />
                </div>
                <div class="form-group">
                  <label for="sector">Select Sector (optional)</label>
                  <select id="sector" name="sector" aria-label="Select Sector">
                    <option value="">— Select a sector —</option>
                    <option>Healthcare &amp; Medical</option>
                    <option>Banking &amp; Finance</option>
                    <option>Insurance</option>
                    <option>Real Estate &amp; Property</option>
                    <option>Construction &amp; Infrastructure</option>
                    <option>Technology &amp; Startups</option>
                    <option>Shipping &amp; Maritime</option>
                    <option>Corporate &amp; Commercial</option>
                    <option>Family &amp; Private Client</option>
                    <option>Government &amp; Regulatory</option>
                    <option>Other</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label for="message">Your Message *</label>
                <textarea id="message" name="message" aria-label="Your message"
                  placeholder="Briefly describe your legal matter..." required></textarea>
              </div>
              <div class="form-submit">
                <button type="submit" class="btn-primary">Send Message</button>
                <span class="form-note">We respond within 1 business day.</span>
              </div>
              <div class="form-success" id="formSuccess" role="status" aria-live="polite">
                Thank you. Your message has been received. A member of our team will be in touch shortly.
              </div>
              <div class="form-note" id="formError" role="alert" aria-live="polite"
                style="display:none;color:#b42318;margin-top:16px;"></div>
            </form>
          </div>
        </div>
      </div>

      <div class="contact-subsections-row">
        <div class="contact-subsection">
          <span class="eyebrow">Social</span>
          <div class="contact-social">
            <a href="http://linkedin.com/company/libra-legal-consultancy" class="social-icon contact-social-icon"
              title="LinkedIn" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">in</a>
            <a href="http://instagram.com/libralegalconsultancy" class="social-icon contact-social-icon"
              title="Instagram" aria-label="Instagram" target="_blank" rel="noopener noreferrer">IG</a>
            <a href="https://www.facebook.com/libralegalconsultancy" class="social-icon contact-social-icon"
              title="Facebook" aria-label="Facebook" target="_blank" rel="noopener noreferrer">f</a>
            <a href="http://tiktok.com/@libra.legal.consu" class="social-icon contact-social-icon" title="TikTok"
              aria-label="TikTok" target="_blank" rel="noopener noreferrer">TK</a>
          </div>
        </div>

        <div class="contact-subsection">
          <span class="eyebrow">Office Hours</span>
          <p>Sunday – Thursday: 9:00 AM – 6:00 PM GST<br>Friday – Saturday: By appointment only</p>
        </div>

        <div class="contact-subsection">
          <span class="eyebrow">Practice Areas</span>
          <p>We advise across 26 specialist practice areas. <a href="/services">View all practice areas →</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section-pad-sm contact-location-band">
    <div class="cta-overlay"></div>
    <div class="container">
      <div class="cta-grid">
        <div class="cta-left">
          <span class="eyebrow">Location</span>
          <h2>Dubai, United Arab Emirates & Egypt</h2>
          <p>Libra Legal Consultancy operates from Dubai and Egypt, serving clients across the UAE, GCC, North Africa,
            and internationally.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-map-section">
    <div class="container">
      <div class="contact-map-shell fade-in">
        <div class="contact-map-copy">
          <span class="eyebrow">Visit Us</span>
          <h3>Find Libra Legal Consultancy in Dubai</h3>
          <p>Our office is conveniently located in Dubai for in-person consultations, strategic meetings, and ongoing
            client support.</p>
        </div>
        <div class="contact-map-frame">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3608.150716660198!2d55.3272087759313!3d25.265514928929267!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3e5f5d18ddf1ebb9%3A0xfc98888959c5c4a5!2sLibra%20Legal%20Consultancy!5e0!3m2!1sen!2sin!4v1777893520853!5m2!1sen!2sin"
            width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </section>

  <div id="footer-placeholder"></div>

  <script src="/shared.js"></script>
  <script>
    renderLayout('contact');
    initFadeIn();

    const form = document.getElementById('contactForm');
    const success = document.getElementById('formSuccess');
    const error = document.getElementById('formError');
    const submitButton = form.querySelector('button[type="submit"]');
    const defaultButtonText = submitButton.textContent;

    function setSubmittingState(isSubmitting) {
      submitButton.disabled = isSubmitting;
      submitButton.textContent = isSubmitting ? 'Sending...' : defaultButtonText;
      submitButton.setAttribute('aria-busy', String(isSubmitting));
    }

    function showError(message) {
      error.textContent = message;
      error.style.display = 'block';
      success.style.display = 'none';
    }

    function clearMessages() {
      error.textContent = '';
      error.style.display = 'none';
      success.style.display = 'none';
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearMessages();

      if (!form.reportValidity()) {
        return;
      }

      const formData = new FormData(form);
      const accessKey = String(formData.get('access_key') || '').trim();

      if (!accessKey) {
        showError('The contact form is temporarily unavailable. Please try again shortly.');
        return;
      }

      setSubmittingState(true);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            Accept: 'application/json'
          },
          body: formData
        });

        let result = {};
        try {
          result = await response.json();
        } catch (parseError) {
          result = {};
        }

        const errorMessage =
          result.message ||
          (result.body && result.body.message) ||
          'Unable to send your message right now.';

        if (!response.ok || !result.success) {
          throw new Error(errorMessage);
        }

        form.reset();
        success.style.display = 'block';
      } catch (submissionError) {
        showError(submissionError.message || 'Unable to send your message right now. Please try again later.');
      } finally {
        setSubmittingState(false);
      }
    });
  </script>
</body>

</html>