<aside class="admin-sidebar">
  <div class="admin-sidebar-top">
    <a href="/admin/dashboard" class="admin-brand">
      <span class="admin-brand-mark">
        <img src="/assets/libralegalLOGO.png" alt="Libra Legal Consultancy logo" class="admin-brand-image" />
      </span>
      <span class="admin-brand-copy">
        <strong>Libra Admin</strong>
        <span>Content management</span>
      </span>
    </a>

    <div class="admin-sidebar-user">
      <span class="admin-kicker">Signed In</span>
      <strong><%= adminUser.fullName %></strong>
      <span><%= adminUser.email %></span>
    </div>
  </div>

  <nav class="admin-side-nav" aria-label="Admin navigation">
    <a href="/admin/dashboard?section=overview" class="admin-side-link <%= currentSection === 'overview' ? 'active' : '' %>">Overview</a>
    <a href="/admin/dashboard?section=homepage" class="admin-side-link <%= currentSection === 'homepage' ? 'active' : '' %>">Homepage</a>
    <a href="/admin/dashboard?section=blogs" class="admin-side-link <%= currentSection === 'blogs' ? 'active' : '' %>">Blogs</a>
    <a href="/admin/dashboard?section=services" class="admin-side-link <%= currentSection === 'services' ? 'active' : '' %>">Services</a>
  </nav>

  <div class="admin-sidebar-actions">
    <a href="/admin/homepage/edit" class="admin-btn">Edit Homepage</a>
    <a href="/admin/blogs/new" class="admin-btn">New Blog Post</a>
    <a href="/admin/services/new" class="admin-btn-secondary">New Service Page</a>
  </div>

  <form method="post" action="/admin/logout" class="admin-sidebar-logout">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <button type="submit" class="admin-btn-secondary">Sign Out</button>
  </form>
</aside>
