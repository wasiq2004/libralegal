<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin CMS | Libra Legal Consultancy</title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="stylesheet" href="/admin.css" />
</head>
<body class="admin-body">
  <main class="admin-shell">
    <div class="admin-app admin-wrap">
      <%- include('partials/sidebar', { adminUser, csrfToken, currentSection }) %>

      <section class="admin-main">
        <div class="admin-head admin-head-main">
          <div>
            <span class="admin-kicker">Content CMS</span>
            <h1>Content Dashboard</h1>
            <p class="admin-muted">Manage blogs and services from a focused workspace with section-based navigation.</p>
          </div>
        </div>

        <% if (flashSuccess) { %>
          <div class="admin-alert success"><%= flashSuccess %></div>
        <% } %>

        <% if (flashError) { %>
          <div class="admin-alert error"><%= flashError %></div>
        <% } %>

        <% const publishedPostsCount = posts.filter((post) => post.status === 'published').length; %>
        <% const publishedServicesCount = services.filter((service) => service.status === 'published').length; %>

        <% if (currentSection === 'overview') { %>
          <section class="admin-panel admin-overview-grid">
            <article class="admin-metric-card">
              <span class="admin-kicker">Blogs</span>
              <strong><%= posts.length %></strong>
              <p><%= publishedPostsCount %> published and visible on the public blog.</p>
            </article>
            <article class="admin-metric-card">
              <span class="admin-kicker">Services</span>
              <strong><%= services.length %></strong>
              <p><%= publishedServicesCount %> published service pages are currently live.</p>
            </article>
            <article class="admin-metric-card">
              <span class="admin-kicker">Workflow</span>
              <strong>Focused</strong>
              <p>Use the sidebar to jump between blog management and service management without leaving the dashboard shell.</p>
            </article>
          </section>
        <% } %>

        <% if (currentSection === 'blogs') { %>
          <section class="admin-panel">
            <div class="admin-panel-head">
              <div>
                <h2>Blog Posts</h2>
                <p>Published posts appear on the public <code>/blogs</code> page automatically.</p>
              </div>
              <a href="/admin/blogs/new" class="admin-btn">Add Blog Post</a>
            </div>
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Post</th>
                    <th>Status</th>
                    <th>Published</th>
                    <th>Slug</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!posts.length) { %>
                    <tr>
                      <td colspan="5">No blog posts have been created yet.</td>
                    </tr>
                  <% } %>

                  <% posts.forEach((post) => { %>
                    <tr>
                      <td>
                        <strong><%= post.title %></strong>
                        <span><%= post.category %></span>
                      </td>
                      <td>
                        <span class="admin-badge <%= post.status %>"><%= post.status %></span>
                      </td>
                      <td><%= post.monthLabel %></td>
                      <td><code><%= post.slug %></code></td>
                      <td>
                        <div class="admin-table-actions">
                          <a href="/blogs/<%= post.slug %>" class="admin-btn-secondary">View</a>
                          <a href="/admin/blogs/<%= post.id %>/edit" class="admin-btn-secondary">Edit</a>
                          <form method="post" action="/admin/blogs/<%= post.id %>/delete" class="admin-inline-form" onsubmit="return confirm('Delete this blog post permanently?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <button type="submit" class="admin-btn-danger">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>

        <% if (currentSection === 'services') { %>
          <section class="admin-panel">
            <div class="admin-panel-head">
              <div>
                <h2>Service Pages</h2>
                <p>The services listing and each service detail page stay synced from these records.</p>
              </div>
              <a href="/admin/services/new" class="admin-btn">Add Service Page</a>
            </div>
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Order</th>
                    <th>Service</th>
                    <th>Status</th>
                    <th>Slug</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!services.length) { %>
                    <tr>
                      <td colspan="5">No service pages are available yet.</td>
                    </tr>
                  <% } %>

                  <% services.forEach((service) => { %>
                    <tr>
                      <td><strong><%= service.numberLabel %></strong></td>
                      <td>
                        <strong><%= service.title %></strong>
                        <% if (service.isReadOnly) { %>
                          <span>Static source only. Connect MySQL to edit or delete.</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="admin-badge <%= service.status %>"><%= service.status %></span>
                      </td>
                      <td><code><%= service.slug %></code></td>
                      <td>
                        <div class="admin-table-actions">
                          <a href="/services/<%= service.slug %>.html" class="admin-btn-secondary">View</a>
                          <% if (service.id) { %>
                            <a href="/admin/services/<%= service.id %>/edit" class="admin-btn-secondary">Edit</a>
                            <form method="post" action="/admin/services/<%= service.id %>/delete" class="admin-inline-form" onsubmit="return confirm('Delete this service page permanently?');">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button type="submit" class="admin-btn-danger">Delete</button>
                            </form>
                          <% } else { %>
                            <span class="admin-inline-note">Read only</span>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>
      </section>
    </div>
  </main>
</body>
</html>
